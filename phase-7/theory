/*
Destructuring
Destructuring is a way to extract values from arrays or objects and assign them to variables easily.

Array Destructuring
Example:
const arr = [10, 20, 30];
const [a, b, c] = arr;
console.log(a); // 10
console.log(b); // 20

Swapping Variables:
let x = 1, y = 2;

[x, y] = [y, x];

console.log(x, y); // 2, 1


2. Object Destructuring
Basic Example:
const user = {
  name: "Aman",
  age: 22
};

const { name, age } = user;

console.log(name); // Aman
*/

/*
1. Spread Operator (...)

👉 Used to expand/unpack elements

Example

const arr1 = [1, 2];
const arr2 = [3, 4];

const result = [...arr1, ...arr2];

console.log(result); // [1,2,3,4]

 Rest Operator (...)
👉 Used to collect values into one variable
example

const [a, ...rest] = [1, 2, 3, 4];

console.log(a);    // 1
console.log(rest); // [2,3,4]

const { name, ...others } = {
  name: "Aman",
  age: 22,
  city: "Delhi"
};

console.log(others);

