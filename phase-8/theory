2. Throttle 
👉 “Allow execution only once every X milliseconds”

example 
function throttle(fn, limit) {
  let lastCall = 0;

  return function (...args) {
    const now = Date.now();

    if (now - lastCall >= limit) {
      lastCall = now;
      fn.apply(this, args);
    }
  };
}
  throttledFn();
throttledFn();
throttledFn();

